{
  "kind": "collectionType",
  "collectionName": "quotes",
  "info": {
    "singularName": "quote",
    "pluralName": "quotes",
    "displayName": "Quote"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "reference": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "clientType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "particulier",
        "entreprise"
      ]
    },
    "lastName": {
      "type": "string",
      "required": true
    },
    "firstName": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "adress": {
      "type": "text",
      "required": true
    },
    "eventName": {
      "type": "string",
      "required": true
    },
    "companyName": {
      "type": "string"
    },
    "vatNumber": {
      "type": "string"
    },
    "siretNumber": {
      "type": "string"
    },
    "items": {
      "type": "component",
      "component": "quote.quote-item",
      "repeatable": true
    }
  }
}
